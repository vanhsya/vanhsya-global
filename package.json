{
  "name": "vanhsya-website",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\"",
    "dev": "next dev --webpack",
    "dev:clean": "npm run clean && npm run dev",
    "build": "next build --webpack",
    "postinstall": "npx update-browserslist-db@latest --yes || true",
    "spell": "cspell --config ./cspell.json --no-progress --no-must-find-files \"src/**/*.{ts,tsx,css,md}\"",
    "test": "node --test --experimental-strip-types --disable-warning=ExperimentalWarning --disable-warning=MODULE_TYPELESS_PACKAGE_JSON",
    "prestart": "npm run build",
    "start": "next start",
    "lint": "eslint src --max-warnings 0"
  },
  "dependencies": {
    "@ai-sdk/openai": "^1.0.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@types/three": "^0.183.1",
    "ai": "^6.0.149",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lottie-react": "^2.4.1",
    "lucide-react": "^0.525.0",
    "next": "^16.2.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-icons": "^5.5.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@netlify/plugin-nextjs": "^5.12.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "cspell": "^8.10.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  },
  "overrides": {
    "brace-expansion": "^5.0.5",
    "minimatch": "^10.0.3"
  }
}
